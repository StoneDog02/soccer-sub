# Supabase (https://supabase.com/dashboard)
# For email verification: Authentication → Providers → Email → enable "Confirm email".
# Add redirect URL: http://localhost:3000/auth/callback (and production URL when deployed).
# Authentication → URL Configuration → Site URL should match your app origin.
# Use the project URL only (https://YOUR-REF.supabase.co) — not /auth/v1 or /rest/v1.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
# Browser client (same values as above; VITE_ prefix required for client-side)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
# Server-only: highlight insert + credit decrement (keep secret)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Create products/prices in Stripe Dashboard; paste IDs here when ready
STRIPE_PRICE_SUBSCRIPTION=price_...
STRIPE_PRICE_UPLOAD=price_...

# Optional: allow /signup?invite=... to create scout accounts
SCOUT_INVITE_CODE=change-me

# Public site origin (include scheme). Only scheme+host+port are used (any path is ignored).
# Must match Supabase → Authentication → Site URL and Redirect URLs
# (http://localhost:3000 vs http://127.0.0.1:3000 are different origins).
PUBLIC_SITE_URL=http://localhost:3000
